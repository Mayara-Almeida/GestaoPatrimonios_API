{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "Issuer": "GestaoPatrimoniosAPI", // Quem está emitindo o token
    "Audience": "GestaoPatrimoniosAPI", // Para quem o token é destinado
    "ExpiraEmMinutos": "120" // Tempo de expiração do login do usuário
  }
}
